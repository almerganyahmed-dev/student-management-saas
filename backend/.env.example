ENVIRONMENT=development
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/student_saas

# Auth
JWT_SECRET_KEY=change-me-to-a-long-random-value
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Stripe billing — test-mode keys from https://dashboard.stripe.com/test/apikeys.
# Leave blank in dev and billing endpoints return 503 instead of crashing.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_BASIC=
STRIPE_PRICE_PREMIUM=
FRONTEND_URL=http://localhost:5173
