ENVIRONMENT=staging
# RDS endpoint for the staging database — never the same instance as prod.
DATABASE_URL=postgresql+psycopg://<user>:<password>@<staging-rds-endpoint>:5432/student_saas

# Auth — generate a fresh random value, do not reuse prod's or dev's.
JWT_SECRET_KEY=<generate-with-openssl-rand--hex-32>
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Stripe TEST mode keys/prices — staging should never touch live Stripe data.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_BASIC=price_...
STRIPE_PRICE_PREMIUM=price_...

# The deployed staging frontend's real origin — drives CORS and Stripe redirect URLs.
FRONTEND_URL=https://staging.yourdomain.com
