ENVIRONMENT=production
# Production RDS endpoint — separate instance from staging.
DATABASE_URL=postgresql+psycopg://<user>:<password>@<prod-rds-endpoint>:5432/student_saas

# Auth — generate a fresh random value, do not reuse staging's or dev's.
JWT_SECRET_KEY=<generate-with-openssl-rand--hex-32>
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Stripe LIVE mode keys/prices.
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_BASIC=price_...
STRIPE_PRICE_PREMIUM=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# The deployed production frontend's real origin.
FRONTEND_URL=https://app.yourdomain.com
